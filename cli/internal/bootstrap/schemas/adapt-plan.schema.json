{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "adapt-plan.schema.json",
  "title": "AdaptPlan",
  "description": "Schema for adapt-plan.json (schema_version=1)",
  "type": "object",
  "required": ["schema_version", "detected", "planned_changes", "skipped"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "detected": {
      "type": "object",
      "required": ["languages", "build_tools", "test_runners", "linters", "has_frontend", "has_database", "entry_points"],
      "additionalProperties": false,
      "properties": {
        "languages":     { "type": "array", "items": { "type": "string" } },
        "build_tools":   { "type": "array", "items": { "type": "string" } },
        "test_runners":  { "type": "array", "items": { "type": "string" } },
        "linters":       { "type": "array", "items": { "type": "string" } },
        "has_frontend":  { "type": "boolean" },
        "has_database":  { "type": "boolean" },
        "entry_points":  { "type": "array", "items": { "type": "string" } }
      }
    },
    "planned_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "op", "rationale"],
        "additionalProperties": false,
        "properties": {
          "path":         { "type": "string", "minLength": 1 },
          "op":           { "type": "string", "enum": ["patch", "replace", "create", "delete"] },
          "rationale":    { "type": "string", "minLength": 1 },
          "diff_summary": { "type": "string" }
        }
      }
    },
    "skipped": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "additionalProperties": false,
        "properties": {
          "path":   { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
