cli/cmd/xylem/xylem
cli/claude
cli/copilot
cli/gh
cli/xylem

# Ignore everything under .xylem/ except tracked control-plane definitions and
# the checked-in SoTA snapshot state. Fresh worktrees — including
# .xylem/worktrees/.daemon-root where the daemon runs — must load these files,
# while operational state (phases/, queue files, daemon.pid, dtu/) stays
# ignored.
.xylem/*
!.xylem/HARNESS.md
!.xylem/eval/
!.xylem/eval/**
!.xylem/prompts/
!.xylem/prompts/**
!.xylem/workflows/
!.xylem/workflows/**
!.xylem/state/
.xylem/state/*
!.xylem/state/.gitignore
!.xylem/state/sota-gap-snapshot.json
!.xylem/state/sota-gap-snapshot.schema.json

# DTU checked-in fixtures intentionally seed .xylem scaffolding.
!cli/internal/dtu/testdata/**/.xylem/
!cli/internal/dtu/testdata/**/.xylem/**
field-reports/
.daemon-root/
.xylem/worktrees/
.copilot-worktrees/
.claude/scheduled_tasks.lock
