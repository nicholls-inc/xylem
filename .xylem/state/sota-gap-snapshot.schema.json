{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nicholls-inc.github.io/xylem/sota-gap-snapshot.schema.json",
  "type": "object",
  "required": [
    "version",
    "repo",
    "generated_at",
    "capabilities"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "repo": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "capabilities": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "required": [
          "key",
          "name",
          "layer",
          "status",
          "summary",
          "priority",
          "spec_sections",
          "code_evidence"
        ],
        "additionalProperties": false,
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "layer": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "wired",
              "dormant",
              "not-implemented"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "recommendation": {
            "type": "string"
          },
          "priority": {
            "type": "integer",
            "minimum": 0
          },
          "spec_sections": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "code_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "path",
                "line_start",
                "summary"
              ],
              "additionalProperties": false,
              "properties": {
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "line_start": {
                  "type": "integer",
                  "minimum": 1
                },
                "line_end": {
                  "type": "integer",
                  "minimum": 0
                },
                "summary": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
